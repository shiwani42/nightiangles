# Scandit license key for the HerCode Summer Hack.
#
# Setup:
#   1. Copy this file to .env        ->   cp .env.example .env
#   2. Paste the license key the organizers gave you below.
#   3. Never commit .env. It is already in .gitignore.
#
# In code, read the key from this variable (the Scandit skills show you where
# to wire it in for your platform).

SCANDIT_LICENSE_KEY=your-license-key-here
